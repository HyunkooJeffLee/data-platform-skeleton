{
  "type": "kafka",
  "spec": {
    "dataSchema": {
      "dataSource": "sensor_readings",
      "timestampSpec": {
        "column": "event_time",
        "format": "iso"
      },
      "dimensionsSpec": {
        "dimensions": [
          "device_id",
          "metric",
          "site_code"
        ]
      },
      "metricsSpec": [
        { "type": "count", "name": "reading_count" },
        { "type": "doubleSum", "name": "value_sum", "fieldName": "value" },
        { "type": "doubleMax", "name": "value_max", "fieldName": "value" },
        { "type": "doubleMin", "name": "value_min", "fieldName": "value" }
      ],
      "granularitySpec": {
        "type": "uniform",
        "segmentGranularity": "HOUR",
        "queryGranularity": "MINUTE",
        "rollup": true
      }
    },
    "ioConfig": {
      "type": "kafka",
      "topic": "sensor_readings",
      "inputFormat": {
        "type": "json"
      },
      "consumerProperties": {
        "bootstrap.servers": "localhost:9092"
      },
      "taskCount": 1,
      "replicas": 1,
      "taskDuration": "PT1H",
      "useEarliestOffset": true
    },
    "tuningConfig": {
      "type": "kafka",
      "maxRowsInMemory": 100000,
      "maxRowsPerSegment": 5000000
    }
  }
}
